# Basic
APP_NAME="Simple Order Pay"
PUBLIC_BASE_URL=https://pay.example.com
DOMAIN_NAME=pay.example.com
TZ=Asia/Shanghai
APP_SECRET=replace_with_64_random_chars

# Product
PRODUCT_NAME=PLUS一月
PRODUCT_DESCRIPTION=
PRODUCT_PRICE_CENTS=9900
PRODUCT_CURRENCY=CNY
# Pending orders temporarily lock one inventory item to avoid overselling.
INVENTORY_RESERVATION_MINUTES=10

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_admin_password
ADMIN_PANEL_PATH=/ops-7q4-panel
ADMIN_API_PREFIX=/api/order-ops-7q4
ADMIN_NOTIFY_EMAIL=1159624528@qq.com

# Docker host ports bound only to 127.0.0.1
FRONTEND_HOST_PORT=3001
BACKEND_HOST_PORT=8001

# MySQL
MYSQL_DATABASE=simple_order_pay
MYSQL_USER=simple_order_pay
MYSQL_PASSWORD=replace_with_mysql_user_password
MYSQL_ROOT_PASSWORD=replace_with_mysql_root_password

# Uploads
MAX_UPLOAD_MB=20
ALLOWED_UPLOAD_EXTENSIONS=.jpg,.jpeg,.png,.pdf,.doc,.docx,.xls,.xlsx,.zip,.txt
ALLOWED_UPLOAD_MIME_PREFIXES=image/,application/pdf,application/zip,application/vnd,application/msword,text/plain

# Payment
# mock: local test mode; manual: show your QR code and manually confirm; ezboti: Ezboti revenue API; pay188: 188Pay fiat cashier; xunhupay: XunhuPay/HuPiJiao gateway; alipay: direct Alipay Page Pay; daxpay: DaxPay gateway mode
PAYMENT_MODE=mock

# Manual payment mode
MANUAL_PAYMENT_QR_URL=
MANUAL_PAYMENT_INSTRUCTIONS=请扫码付款，付款后点击“我已付款，等待确认”。管理员会核对收款，10 分钟内发货。

# Alipay official Page Pay
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
ALIPAY_APP_ID=
# Paste PKCS8 app private key body as one line, or include PEM header with \n escaped.
ALIPAY_APP_PRIVATE_KEY=
# Paste Alipay public key body as one line, or include PEM header with \n escaped.
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://pay.example.com/api/payments/alipay/notify
ALIPAY_RETURN_URL=https://pay.example.com/
ALIPAY_SIGN_TYPE=RSA2
ALIPAY_CHARSET=utf-8
ALIPAY_PAGE_PAY_PRODUCT_CODE=FAST_INSTANT_TRADE_PAY
ALIPAY_TIMEOUT_EXPRESS=30m

# DaxPay gateway
DAXPAY_API_URL=https://your-daxpay-gateway.example.com
DAXPAY_APP_ID=
DAXPAY_MCH_NO=
DAXPAY_SIGN_SECRET=
DAXPAY_NOTIFY_URL=https://pay.example.com/api/payments/daxpay/notify
DAXPAY_RETURN_URL=https://pay.example.com/
DAXPAY_SIGN_TYPE=HMAC_SHA256
DAXPAY_CHANNEL=wechat_pay
DAXPAY_METHOD=qrcode
DAXPAY_REQUEST_TIMEOUT_SECONDS=15

# XunhuPay / HuPiJiao gateway
XUNHUPAY_GATEWAY_URL=https://api.xunhupay.com/payment/do.html
XUNHUPAY_APP_ID=
XUNHUPAY_APP_SECRET=
XUNHUPAY_NOTIFY_URL=https://pay.example.com/api/payments/xunhupay/notify
XUNHUPAY_RETURN_URL=https://pay.example.com/
XUNHUPAY_VERSION=1.1
XUNHUPAY_PLUGINS=simple-order-pay
XUNHUPAY_REQUEST_TIMEOUT_SECONDS=15

# 188Pay fiat cashier
PAY188_GATEWAY_URL=https://api2.188pay.top/submit.php
PAY188_MERCHANT_ID=
PAY188_SECRET_KEY=
# Docs currently list fiat_alipay as the public fiat method. If 188Pay enables WeChat for your merchant, fill their provided method value here.
PAY188_PAYMENT_METHOD=fiat_alipay
PAY188_COIN_TYPE=
PAY188_NOTIFY_URL=https://pay.example.com/api/payments/pay188/notify
PAY188_RETURN_URL=https://pay.example.com/
PAY188_REQUEST_TIMEOUT_SECONDS=15

# Ezboti revenue API
EZBOTI_API_URL=https://revenue.ezboti.com/api/v1/server
EZBOTI_PROJECT_ID=
EZBOTI_PROJECT_SECRET=
# Fill one paywall selector from Ezboti project
EZBOTI_PAYWALL_ID=
EZBOTI_PAYWALL_ALIAS=
EZBOTI_EXTRA_PAYWALL_ID=
EZBOTI_EXTRA_PAYWALL_ALIAS=
# Optional: restrict paid detection to one equity. Leave blank to accept any charged usable balance.
EZBOTI_EQUITY_ID=
EZBOTI_EQUITY_ALIAS=
EZBOTI_REQUIRE_CHARGED=true
EZBOTI_REQUIRE_USABLE=true
EZBOTI_REQUEST_TIMEOUT_SECONDS=15

# Email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME="Simple Order Pay"
SMTP_USE_SSL=true
SMTP_USE_TLS=false
SMTP_TIMEOUT_SECONDS=15

# Nginx
CLIENT_MAX_BODY_SIZE=25m
